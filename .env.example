# =============================================================================
# what-it-do — environment configuration
# Copy this file to `.env.local` and fill in the values you have. Every source
# degrades gracefully: a missing key just means that source contributes nothing
# (it never breaks the ingest run).
# =============================================================================

# --- Event source: Ticketmaster --------------------------------------------
# Structured Austin events (image-rich). Free key: https://developer.ticketmaster.com
# Without it, lib/scrapers/ticketmaster.ts returns [] and logs a warning.
TICKETMASTER_API_KEY=

# --- Event source: Eventbrite -----------------------------------------------
# NOTE: Eventbrite killed its public event-search API in Feb 2020, so NO token
# is needed anymore — lib/scrapers/eventbrite.ts scrapes Eventbrite's public
# Austin listing pages (schema.org JSON-LD). Nothing to configure here.

# --- LLM extraction: Google Gemini ------------------------------------------
# REQUIRED for newspapers, social, YouTube, and page-crawler sources. Those are
# prose feeds; each item is run through Gemini to pull out concrete, dated
# events. No key -> those four sources return []. Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Free-tier safety rails, enforced centrally by the one Gemini client. The free
# AI Studio tier is limited by request COUNT (not dollars). Defaults are tuned
# for the free tier; raise them for the paid tier.
# GEMINI_DAILY_BUDGET=200   # max Gemini requests per day (ingest run)
# GEMINI_RPM=5              # max Gemini requests per minute (5 is the free-tier ceiling)

# --- Event source: SeatGeek -------------------------------------------------
# Free client id: https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=

# --- Event source: YouTube --------------------------------------------------
# YouTube Data API v3 key: https://console.cloud.google.com (needs GEMINI_API_KEY too)
YOUTUBE_API_KEY=

# --- Map view: Google Geocoding + Maps JS API --------------------------------
# Server-side key for venue geocoding (lib/geocode.ts), used once per unique
# venue at ingest time (cached in the `venues` table — never re-queried once
# cached). Enable the "Geocoding API" for it in https://console.cloud.google.com
# Without it, no venues get lat/lng and the map view simply shows no pins —
# nothing else breaks.
GOOGLE_GEOCODING_API_KEY=
# GEOCODE_DAILY_BUDGET=500   # max geocoding requests per day (ingest run)

# Client-side key for rendering the Maps JS API in the browser
# (components/MapView.tsx). NOTE: this key ships inside the public JS bundle —
# anyone can read it. In Google Cloud Console, restrict it with an HTTP
# referrer restriction (Credentials → your key → Application restrictions →
# HTTP referrers) scoped to your production domain(s); do NOT reuse the
# unrestricted GOOGLE_GEOCODING_API_KEY here — use a second, separate key with
# the "Maps JavaScript API" enabled. Without this key, the map view renders a
# "not configured" placeholder instead of a broken map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Optional: extend sources without code changes --------------------------
# Extra newspaper/blog RSS feeds. Format: url|source,url|source
# NEWSPAPER_FEEDS=https://example.com/feed|newspaper:example
# Extra pages to crawl each ingest (aggregators, link-in-bio pages):
# CRAWL_URLS=https://365thingsaustin.com,https://do512.com
# Headless-browser render service for JS-heavy/blocked pages (crawl4ai, Browserless, etc.):
# BROWSER_FETCH_URL=
# BROWSER_FETCH_TOKEN=

# --- Production: database + cron auth ---------------------------------------
# Local dev uses embedded PGlite and needs none of these. Set them for prod.
#
# DATABASE_URL selects the production Postgres. Use the Supabase Supavisor
# TRANSACTION pooler connection string, port 6543 (Dashboard → Project Settings
# → Database → Connection pooling → "Transaction" tab → URI) — NOT the Session
# pooler (port 5432): the app opens a `pg` Pool per serverless instance, and
# Session mode's low concurrent-client cap (its own `pool_size`, e.g. 15) gets
# exhausted by ordinary traffic, failing with "max clients reached in session
# mode". The one-off `npm run migrate` script also accepts either mode, since
# it only ever opens one connection.
# When DATABASE_URL is set, the app connects via this pool and PGlite is off;
# when unset, the app runs entirely on embedded PGlite (zero credentials).
# Apply migrations to it once with:  npm run migrate
DATABASE_URL=
# TLS certificate verification is ON by default for any non-local DATABASE_URL
# (Supavisor's cert is publicly CA-signed, so this just works). Only set this
# to "true" if you're deploying against a Postgres with a self-signed cert you
# can't otherwise trust — it disables certificate verification for that
# connection, which allows a network-level attacker to impersonate the DB.
# DATABASE_SSL_INSECURE=true
# Bearer token that guards the mutation/cron routes (/api/ingest, /api/import,
# /api/featured, /api/email/digest). REQUIRED in production — without it those
# routes refuse to run (503) instead of running open. Vercel Cron sends it
# automatically once set. Generate: openssl rand -hex 32
CRON_SECRET=

# Canonical public origin, e.g. https://whatitdo.app — used for unsubscribe
# links in emails. Preferred over VERCEL_URL (the per-deployment host).
SITE_URL=

# --- Optional: email digests ------------------------------------------------
# RESEND_API_KEY=
# Verified sender for digest/confirmation emails, e.g. "What It Do Austin
# <hello@yourdomain.com>". Without it, Resend's sandbox sender is used, which
# only delivers to the Resend account owner.
# EMAIL_FROM=
